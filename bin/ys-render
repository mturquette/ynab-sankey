#!/usr/bin/env node

import fs from 'fs';
import { dirname, join } from 'path';
import { fileURLToPath } from 'url';

const __dirname = dirname(fileURLToPath(import.meta.url));

/**
 * Parse command line arguments
 * @returns {Object} Parsed arguments
 */
function parseArgs() {
  const args = {
    input: null,
    output: null,
    open: false
  };

  process.argv.slice(2).forEach(arg => {
    if (arg.startsWith('--input=')) {
      args.input = arg.split('=')[1];
    } else if (arg.startsWith('--output=')) {
      args.output = arg.split('=')[1];
    } else if (arg === '--open') {
      args.open = true;
    } else if (arg === '--help' || arg === '-h') {
      console.log(`
YNAB Sankey D3.js Renderer

Usage: ys-render [options]

Options:
  --input=<path>    Path to D3 sankey JSON file (default: latest in data/processed/)
  --output=<path>   Output HTML file path (default: output/ynab-sankey-d3-<daterange>.html)
  --open            Open the generated HTML file in default browser
  -h, --help        Show this help message

Examples:
  ys-render
  ys-render --open
  ys-render --input=data/processed/d3-sankey-2026-02.json
  ys-render --input=data/processed/d3-sankey-2026-02.json --output=my-viz.html --open

Generated by: bin/ys-render
      `);
      process.exit(0);
    }
  });

  return args;
}

/**
 * Find the latest D3 sankey data file in data/processed/
 * @returns {string} Path to the latest file
 */
function findLatestD3Data() {
  const dataDir = join(process.cwd(), 'data', 'processed');

  if (!fs.existsSync(dataDir)) {
    throw new Error(`Data directory not found: ${dataDir}`);
  }

  const files = fs.readdirSync(dataDir)
    .filter(f => f.startsWith('d3-sankey-') && f.endsWith('.json'))
    .sort()
    .reverse();

  if (files.length === 0) {
    throw new Error('No d3-sankey-*.json files found in data/processed/. Run "npm run build-d3" first.');
  }

  const filePath = join(dataDir, files[0]);
  console.log(`📂 Using input file: ${filePath}`);
  return filePath;
}

/**
 * Main rendering function
 */
async function main() {
  console.log('🎨 YNAB Sankey D3.js Renderer\n');

  const args = parseArgs();

  // Find input file (auto-detect from data/processed/ if not specified)
  const inputFile = args.input || findLatestD3Data();

  // Verify input file exists
  if (!fs.existsSync(inputFile)) {
    throw new Error(`Input file not found: ${inputFile}`);
  }

  // Load D3 sankey data
  console.log('📖 Loading sankey data...');
  const data = JSON.parse(fs.readFileSync(inputFile, 'utf8'));

  // Validate data structure
  if (!data.nodes || !data.links || !data.metadata) {
    throw new Error('Invalid D3 sankey data format. Expected: { nodes, links, metadata }');
  }

  console.log(`   - ${data.nodes.length} nodes`);
  console.log(`   - ${data.links.length} links`);
  console.log(`   - Date range: ${data.metadata.dateRange}`);

  // Load template
  const templatePath = join(__dirname, '..', 'src', 'd3-sankey-template.html');

  if (!fs.existsSync(templatePath)) {
    throw new Error(`Template not found: ${templatePath}`);
  }

  console.log('📄 Loading HTML template...');
  let html = fs.readFileSync(templatePath, 'utf8');

  // Replace placeholders
  console.log('🔧 Injecting data into template...');
  html = html.replace('{{SANKEY_DATA}}', JSON.stringify(data, null, 2));
  html = html.replace(/{{TITLE}}/g, 'YNAB Budget Flow');
  html = html.replace(/{{SUBTITLE}}/g, data.metadata.dateRange || 'Budget Flow');
  html = html.replace(/{{TIMESTAMP}}/g, new Date().toLocaleString());

  // Determine output path
  const outputFile = args.output ||
    join(process.cwd(), 'output', `ynab-sankey-d3-${data.metadata.dateRange}.html`);

  // Ensure output directory exists
  fs.mkdirSync(dirname(outputFile), { recursive: true });

  // Write HTML file
  console.log('💾 Writing HTML file...');
  fs.writeFileSync(outputFile, html);

  console.log(`\n✅ Generated: ${outputFile}`);
  console.log(`   File size: ${(fs.statSync(outputFile).size / 1024).toFixed(2)} KB`);

  // Open in browser if requested
  if (args.open) {
    console.log('\n🌐 Opening in browser...');
    const { exec } = await import('child_process');
    const command = process.platform === 'darwin' ? 'open' :
                   process.platform === 'win32' ? 'start' : 'xdg-open';
    exec(`${command} "${outputFile}"`);
  }

  console.log('\n✨ Done!\n');
}

// Run main function
main().catch(error => {
  console.error('\n❌ Error:', error.message);
  console.error('\nFor help, run: ys-render --help\n');
  process.exit(1);
});
