#!/usr/bin/env node

import { join } from 'path';
import config, { validateConfig } from '../src/config.js';
import { ynabClient } from '../src/ynab-api.js';
import { getDateRange } from '../src/utils/date-range.js';
import { writeJSON } from '../src/utils/file-io.js';
import { isCacheValid, getCachePath } from '../src/utils/cache-manager.js';

/**
 * ys-fetch
 * Fetches data from YNAB API, fixes up the amounts & caches it to disk
 *
 * Usage:
 *   node bin/ys-fetch [options]
 *
 * Options:
 *   --range=<month|ytd|YYYY-MM-DD|YYYY-MM-DD:YYYY-MM-DD>  Date range (default: month)
 *   --budget-id=<id>         YNAB budget ID (default: from .env)
 *   --force                  Force refresh even if cache valid
 *   --output-dir=<path>      Output directory (default: data/ynab)
 *   --max-age=<hours>        Cache TTL in hours (default: 24)
 *   --debug                  Enable debug logging
 *   --debugverbose           Enable verbose debug logging (transactions)
 */

/**
 * Parses command line arguments
 * @returns {Object} Parsed arguments
 */
function parseArgs() {
  const args = {
    range: 'month',
    budgetId: config.ynab.budgetId,
    force: false,
    outputDir: null,
    maxAge: 24,
    debug: false
  };

  process.argv.slice(2).forEach(arg => {
    if (arg.startsWith('--range=')) {
      args.range = arg.split('=')[1];
    } else if (arg.startsWith('--budget-id=')) {
      args.budgetId = arg.split('=')[1];
    } else if (arg === '--force') {
      args.force = true;
    } else if (arg.startsWith('--output-dir=')) {
      args.outputDir = arg.split('=')[1];
    } else if (arg.startsWith('--max-age=')) {
      args.maxAge = parseInt(arg.split('=')[1], 10);
    } else if (arg === '--debug') {
      args.debug = true;
    } else if (arg === '--debugverbose') {
      args.debug = true;
      args.debugverbose = true;
    }
  });

  return args;
}

/**
 * Main function
 */
async function main() {
  try {
    console.log('📊 YNAB Data Fetcher\n');

    // Parse arguments
    const args = parseArgs();

    if (args.debug) {
      console.log('Debug mode enabled\n');
    }

    // Validate configuration
    validateConfig();

    // Get date range
    const dateRange = getDateRange(args.range);
    console.log(`Date range: ${dateRange.startDate} to ${dateRange.endDate}`);
    console.log(`Label: ${dateRange.label}\n`);

    // Check cache validity
    const cacheValid = isCacheValid(dateRange, args.maxAge);
    const cacheDir = args.outputDir || getCachePath(dateRange, 'ynab');

    // bail out early if cache is valid and we're not forcing a refresh
    if (!args.force) {
      if (cacheValid) {
        console.log('✅ Using cached data (still fresh)');
        console.log(`   Cache location: ${cacheDir}`);
        console.log(`\n💡 Use --force to refresh from API`);
        process.exit(0);
      }
    } else { // we are forcing a refresh
      if (cacheValid) {
        console.log('🔄 Force refresh requested, ignoring cache\n');
      } else {
        console.log('🔄 Cache is stale or missing, fetching from API\n');
      }
    }

    // Fetch data from YNAB API
    console.log('Fetching from YNAB API...');

    const [transactions, accounts, categoryGroups] = await Promise.all([
      ynabClient.getTransactions(
        args.budgetId,
        dateRange.startDate,
        dateRange.endDate
      ),
      ynabClient.getAccounts(args.budgetId),
      ynabClient.getCategories(args.budgetId)
    ]);

    console.log(`   ✓ ${transactions.length} transactions`);
    console.log(`   ✓ ${accounts.length} accounts`);
    console.log(`   ✓ ${categoryGroups.length} category groups\n`);

    // primary output from --debug
    if (args.debug) {
      console.log('Accounts:');
      accounts.forEach(acct => {
        const closed = acct.closed ? '[CLOSED]' : '';
        const on_budget = acct.on_budget ? '[ON-BUDGET]' : '[OFF-BUDGET]';
        console.log(`  - ${acct.name} (${acct.type}) ${on_budget} ${closed}`);
      });
      console.log();
    }

    // transactions are noisy. hide behind --debugverbose
    if (args.debugverbose) {
      console.log('Transactions:');
      transactions.forEach(transaction => {
        const deleted = transaction.deleted ? '[DELETED]' : '';
        const approved = transaction.approved ? '' : '[NOT APPROVED]';
        const cleared = transaction.cleared ? '' : '[NOT CLEARED]';
        const debt_transaction_type = transaction.debt_transaction_type ? transaction.debt_transaction_type : '';
        console.log(`  - ${approved}${cleared}${debt_transaction_type}${deleted} subtransactions: ${transaction.subtransactions.length}`);
      })
      console.log();
    }

    // Build two lookup maps for quick access:
    //    category_name -> category object
    //    group_name -> group object
    // Also logs the category listing under --debug.
    const categoryByName = {};
    const groupByName = {};

    if (args.debug) console.log('Categories -> Budgets:');
    categoryGroups.forEach(group => {
      groupByName[group.name] = group;

      if (args.debug) {
        const hidden = group.hidden ? '[HIDDEN]' : '';
        const deleted = group.deleted ? '[DELETED]' : '';
        console.log(`  - ${group.name} ${hidden} ${deleted}`);
      }

      group.categories.forEach(category => {
        categoryByName[category.name] = category;

        if (args.debug) {
          const hidden = category.hidden ? '[HIDDEN]' : '';
          console.log(`    - ${category.name} ${hidden}`);
        }

        // while we are here sum up budgeted, activity & balance for groups
        group.budgeted += category.budgeted;
        group.activity += category.activity;
        group.balance += category.balance;
      });
    });
    if (args.debug) console.log();

    // Sum transaction amounts into each category & group
    // Account for subtranscations (split transactions on YNAB)
    transactions.forEach(transaction => { const entries = (transaction.subtransactions && transaction.subtransactions.length > 0)
        ? transaction.subtransactions
        : [transaction];

      entries.forEach(entry => {
        // Rename "Uncategorized" (YNAB's label for account-to-account transfers)
        // to a descriptive label. This is the single point of rename: it updates
        // the transaction entry, resolves the category via the original API name,
        // and renames the category object itself for downstream consumers.
        if (entry.category_name === config.uncategorizedName) {
          entry.category_name = config.transferCategoryName;
        }

        let category = categoryByName[entry.category_name]
          || categoryByName[config.uncategorizedName];
        if (!category) return;

        // Lazily rename the category object and update the lookup map
        if (category.name === config.uncategorizedName) {
          category.name = config.transferCategoryName;
          categoryByName[config.transferCategoryName] = category;
        }

        let group = groupByName[category.category_group_name];
        if (!group) return;

        // Lazily rename the "Uncategorized" group to match
        if (group.name === config.uncategorizedName) {
          group.name = config.transferCategoryName;
          groupByName[config.transferCategoryName] = group;
        }

        if (category.sumTransactionAmount === undefined) {
          category.sumTransactionAmount = 0;
        }
        if (group.sumTransactionAmount === undefined) {
          group.sumTransactionAmount = 0;
        }

        // add the transcation amount to a running total for both the category & group
        category.sumTransactionAmount += entry.amount;
        group.sumTransactionAmount += entry.amount;

        if (args.debugverbose) {
          console.log(`category ${category.name} sum ${category.sumTransactionAmount}`)
          console.log(`group ${group.name} sum ${group.sumTransactionAmount}`)
          console.log();
        }
      });
    });

    // Save data to disk
    console.log('Saving data to cache...');

    writeJSON(join(cacheDir, 'transactions.json'), transactions);
    console.log(`   ✓ Saved transactions.json`);

    writeJSON(join(cacheDir, 'accounts.json'), accounts);
    console.log(`   ✓ Saved accounts.json`);

    writeJSON(join(cacheDir, 'categories.json'), categoryGroups);
    console.log(`   ✓ Saved categories.json`);

    // Compute the delta between inflow and total expenses (in milliunits).
    // Both lookups use the maps already built above — no extra iteration needed.
    const inflowCategory = categoryByName['Inflow: Ready to Assign'];
    const incomeMilliunits = inflowCategory ? (inflowCategory.sumTransactionAmount || 0) : 0;
    const expenseMilliunits = Object.values(groupByName)
      .filter(g => g.sumTransactionAmount < 0)
      .reduce((sum, g) => sum + g.sumTransactionAmount, 0);
    const deltaMilliunits = incomeMilliunits + expenseMilliunits; // expenses are negative

    // Create metadata
    const metadata = {
      fetchedAt: new Date().toISOString(),
      dateRange: {
        start: dateRange.startDate,
        end: dateRange.endDate,
        label: dateRange.label
      },
      budgetId: args.budgetId,
      transactionCount: transactions.length,
      accountCount: accounts.length,
      categoryGroupCount: categoryGroups.length,
      incomeMilliunits,
      expenseMilliunits,
      deltaMilliunits
    };

    writeJSON(join(cacheDir, 'metadata.json'), metadata);
    console.log(`   ✓ Saved metadata.json\n`);

    console.log('✅ Data successfully cached!');
    console.log(`   Location: ${cacheDir}`);

  } catch (error) {
    console.error('\n❌ Error:', error.message);

    if (error.stack && process.env.DEBUG) {
      console.error('\nStack trace:');
      console.error(error.stack);
    }

    process.exit(1);
  }
}

// Run the utility
main();
